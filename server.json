{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.mlintangmz2765/scholar",
  "description": "Hardened Scholar MCP for deep academic research (Scopus, OpenAlex, Unpaywall) with PDF vision.",
  "repository": {
    "url": "https://github.com/mlintangmz2765/Scholar-MCP",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "scholar-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "python",
      "environmentVariables": [
        {
          "name": "SCOPUS_API_KEY",
          "description": "Your Elsevier Scopus API Key",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "CONTACT_EMAIL",
          "description": "Email for OpenAlex polite pool and Unpaywall identification",
          "isRequired": true,
          "format": "string"
        },
        {
          "name": "SCOPUS_INST_TOKEN",
          "description": "Optional Elsevier Institutional Token",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "tool": "cortex-agent",
      "version": "1.1.0",
      "hardened": true
    }
  }
}
